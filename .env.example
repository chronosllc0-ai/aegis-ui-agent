# GCP Configuration
GCP_PROJECT_ID=aegis-hackathon
GCP_REGION=us-central1
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview

# Backend Runtime
PORT=8000
LOG_LEVEL=INFO
BROWSER_HEADLESS=true
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# Frontend Runtime
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/navigate

# Auth / OAuth
SESSION_SECRET=replace_with_long_random_secret
SESSION_TTL_SECONDS=604800
COOKIE_SECURE=false
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GITHUB_OAUTH_CLIENT_ID=your_github_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_client_secret
SSO_OIDC_METADATA_URL=https://your-idp/.well-known/openid-configuration
SSO_CLIENT_ID=your_sso_client_id
SSO_CLIENT_SECRET=your_sso_client_secret
SSO_SCOPE=openid email profile
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_SENDER=alerts@yourdomain.com
SMTP_USE_TLS=true

# Optional Integration Keys
FIREBASE_API_KEY=your_firebase_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
DISCORD_BOT_TOKEN=your_discord_bot_token_here
BRAVE_API_KEY=your_brave_api_key_here
