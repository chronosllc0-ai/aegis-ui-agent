# ── Database ──────────────────────────────────────────────────────────
# Leave blank for local SQLite development. Railway should inject its Postgres DATABASE_URL in production.
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────────────────
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ADMIN_EMAILS=  # comma-separated email list for auto-admin assignment
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

# Production split-deploy example:
# PUBLIC_BASE_URL=https://api.mohex.org
# FRONTEND_URL=https://mohex.org
# CORS_ORIGINS=https://mohex.org,https://www.mohex.org
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
#
# If you keep the backend on a Railway-generated domain instead of api.mohex.org:
# PUBLIC_BASE_URL=https://your-service.up.railway.app
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# ── Encryption (BYOK) ───────────────────────────────────────────────
ENCRYPTION_SECRET=change-me-in-production

# ── Default LLM provider ────────────────────────────────────────────
DEFAULT_PROVIDER=google
DEFAULT_MODEL=gemini-2.5-pro

# ── Provider API keys (server-side fallbacks) ────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# ── OAuth (optional) ────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SSO_OIDC_METADATA_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# ── Email sign-in (optional) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=

# ── Runtime ─────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
BROWSER_HEADLESS=true
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
