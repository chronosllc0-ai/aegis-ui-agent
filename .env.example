# ── Database ──────────────────────────────────────────────────────────
# Leave blank for local SQLite development. Railway should inject its Postgres DATABASE_URL in production.
DATABASE_URL=

# ── Auth ─────────────────────────────────────────────────────────────
SESSION_SECRET=
SESSION_TTL_SECONDS=604800
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
ADMIN_EMAILS=  # comma-separated email list for auto-admin assignment
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

# Production split-deploy example:
# PUBLIC_BASE_URL=https://api.mohex.org
# FRONTEND_URL=https://mohex.org
# CORS_ORIGINS=https://mohex.org,https://www.mohex.org
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
#
# If you keep the backend on a Railway-generated domain instead of api.mohex.org:
# PUBLIC_BASE_URL=https://your-service.up.railway.app
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# ── Encryption (BYOK) ───────────────────────────────────────────────
ENCRYPTION_SECRET=change-me-in-production

# ── Default LLM provider ────────────────────────────────────────────
DEFAULT_PROVIDER=google
DEFAULT_MODEL=gemini-2.5-pro

# ── Provider API keys (server-side fallbacks) ────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
BRAVE_SEARCH_API_KEY=  # Optional: Brave Search API key. When set, the built-in web_search tool uses Brave Search. Without it, the tool falls back to DuckDuckGo HTML scraping.

# ── Fireworks AI ──────────────────────────────────────────────────────────────
FIREWORKS_API_KEY=    # Required for Fireworks AI provider (Kimi K2.5 Turbo etc.)
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1  # Optional: override base URL

# ── AWS S3 file storage ───────────────────────────────────────────────────────
# When all three AWS vars are set, generated artifacts (files, images, reports)
# are uploaded to S3 instead of stored on the server's local disk. The DB only
# stores the S3 URL. Pre-signed download links are generated on demand (1 hour TTL).
AWS_ACCESS_KEY_ID=        # AWS IAM access key with s3:PutObject / s3:GetObject / s3:DeleteObject
AWS_SECRET_ACCESS_KEY=    # Corresponding IAM secret key
AWS_S3_BUCKET=            # Target S3 bucket (e.g. aegis-artifacts-prod)
AWS_S3_REGION=us-east-1   # Bucket region (default: us-east-1)

# ── Platform-level agent instruction ────────────────────────────────────────
# Injected at the top of every agent system prompt — authoritative, users cannot override.
# Prefer the live Admin > Agent Config editor (DB-backed). This env var is a
# deploy-time fallback when the DB row has not been set.
AEGIS_GLOBAL_SYSTEM_INSTRUCTION=

# ── OAuth — Authentication (login only) ─────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SSO_OIDC_METADATA_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_SCOPE=openid email profile

# ── OAuth — Connector integrations (broader scopes) ─────────────────
# Separate client IDs for connectors — these request broader scopes
# (e.g. Gmail read/send, Drive access) than the auth-only clients above.
GOOGLE_CONNECTOR_CLIENT_ID=
GOOGLE_CONNECTOR_CLIENT_SECRET=
GITHUB_CONNECTOR_CLIENT_ID=
GITHUB_CONNECTOR_CLIENT_SECRET=
SLACK_CONNECTOR_CLIENT_ID=
SLACK_CONNECTOR_CLIENT_SECRET=
NOTION_CONNECTOR_CLIENT_ID=
NOTION_CONNECTOR_CLIENT_SECRET=
LINEAR_CONNECTOR_CLIENT_ID=
LINEAR_CONNECTOR_CLIENT_SECRET=

# ── Email sign-in (optional) ────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_USE_TLS=true

# ── Runtime ─────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
BROWSER_HEADLESS=true
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# ── Railway / Deployment ────────────────────────────────────────────
RAILWAY_ENVIRONMENT=
RAILWAY_PUBLIC_DOMAIN=
